# Gemini API Configuration
REACT_APP_GEMINI_API_KEY=your_api_key_here
REACT_APP_GEMINI_MODEL=gemini-2.5-flash
REACT_APP_GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Video Generation Configuration (Veo 3.1)
# Aspect ratio options: 16:9 (landscape), 9:16 (portrait), 1:1 (square)
REACT_APP_VIDEO_ASPECT_RATIO=16:9

# Video quality options: standard, high
REACT_APP_VIDEO_QUALITY=standard

# Video generation timeout in milliseconds (default: 5 minutes)
REACT_APP_VIDEO_TIMEOUT=300000

# Development Server
PORT=3000
